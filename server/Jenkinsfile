pipeline {
  agent any

  tools {
    nodejs 'node20'
  }

  environment {
    DOCKER_IMAGE = "tejas663/lms-backend"
    DOCKER_TAG   = "${BUILD_NUMBER}"
    SONAR_SCANNER_HOME = tool 'sonar-scanner'

    // 🔥 ADDITION (GitOps repo)
    GITOPS_REPO = "https://github.com/TejasSavla663/lms-cd-gitops.git"
    HELM_PATH   = "helm/lms-backend"
  }

  stages {

    stage('🔍 Check Changes (server only)') {
      when {
        anyOf {
          branch 'jenkins-cicd'
          branch 'main'
        }
      }
      steps {
        echo "🧠 Monorepo detected — CI will run only if server/ changed"
      }
    }

    stage('📥 Checkout Code') {
      when {
        changeset "server/**"
      }
      steps {
        echo "📥 Checking out source code..."
        checkout scm
        echo "✅ Checkout completed"
      }
    }

    stage('📦 Install Dependencies & Tests') {
      when {
        changeset "server/**"
      }
      steps {
        dir('server') {
          echo "📦 Installing dependencies..."
          sh 'npm ci'
          echo "✅ Dependencies installed"

          echo "🧪 Running tests (optional)..."
          sh 'npm test || echo "⚠️ No tests / tests skipped"'
          echo "✅ Test stage done"
        }
      }
    }

    stage('🔍 SonarQube Scan') {
      when {
        changeset "server/**"
      }
      steps {
        echo "🔍 Starting SonarQube scan..."
        withSonarQubeEnv('sonarqube') {
          withCredentials([string(credentialsId: 'sonar-token', variable: 'SONAR_TOKEN')]) {
            dir('server') {
              sh """
              ${SONAR_SCANNER_HOME}/bin/sonar-scanner \
              -Dsonar.projectKey=lms-backend-server \
              -Dsonar.projectName=lms-backend-server \
              -Dsonar.sources=. \
              -Dsonar.host.url=http://172.17.0.1:9000 \
              -Dsonar.login=${SONAR_TOKEN}
              """
            }
          }
        }
        echo "✅ Sonar scan completed"
      }
    }

    stage('🐳 Build Docker Image') {
      when {
        changeset "server/**"
      }
      steps {
        dir('server') {
          echo "🐳 Building Docker image..."
          sh "docker build -t ${DOCKER_IMAGE}:${DOCKER_TAG} ."
          echo "✅ Image built: ${DOCKER_IMAGE}:${DOCKER_TAG}"
        }
      }
    }

    stage('🛡️ Trivy Scan') {
      when {
        changeset "server/**"
      }
      steps {
        echo "🛡️ Running Trivy scan..."
        sh """
        docker run --rm \
          -v /var/run/docker.sock:/var/run/docker.sock \
          aquasec/trivy image ${DOCKER_IMAGE}:${DOCKER_TAG}
        """
        echo "✅ Trivy scan completed"
      }
    }

    stage('📤 Push to DockerHub') {
      when {
        changeset "server/**"
      }
      steps {
        echo "📤 Pushing image to DockerHub..."
        withCredentials([usernamePassword(
          credentialsId: 'dockerhub-creds',
          usernameVariable: 'DOCKER_USER',
          passwordVariable: 'DOCKER_PASS'
        )]) {
          sh """
          echo "$DOCKER_PASS" | docker login -u "$DOCKER_USER" --password-stdin
          docker push ${DOCKER_IMAGE}:${DOCKER_TAG}
          """
        }
        echo "🚀 Image pushed successfully"
      }
    }

    // 🔥🔥 ONLY NEW STAGE ADDED 🔥🔥
    stage('📝 Update Helm values.yaml (GitOps)') {
      when {
        changeset "server/**"
      }
      steps {
        echo "📝 Updating Helm image tag for ArgoCD..."

        sh """
        rm -rf gitops
        git clone ${GITOPS_REPO} gitops
        cd gitops/${HELM_PATH}

        sed -i 's/tag:.*/tag: "${DOCKER_TAG}"/' values.yaml

        git config user.email "jenkins@ci.com"
        git config user.name "jenkins"

        git add values.yaml
        git commit -m "chore: update backend image to ${DOCKER_TAG}"
        git push
        """

        echo "✅ Helm values updated — ArgoCD will sync automatically"
      }
    }
  }

  post {
    success {
      echo "🎉 CI PIPELINE COMPLETED SUCCESSFULLY"
    }
    failure {
      echo "❌ CI PIPELINE FAILED — Check logs"
    }
    always {
      echo "🧹 Pipeline finished"
    }
  }
}
